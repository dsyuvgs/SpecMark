    - "data":
        "code": "import json\\nimport re\\n\\ndef main(classifier_output: str, user_query:\
          \ str, has_files: str) -> dict:\\n    validated_type = 'invalid_input'\\\
          n    confidence = 0.0\\n    llm_type = ''\\n\\n    has_file = False\\n \
          \   if has_files:\\n        has_files_str = str(has_files).strip()\\n  \
          \      if has_files_str and has_files_str.lower() not in ['none', 'null',\
          \ '[]', '{}', 'false', '']:\\n            has_file = True\\n\\n    prd_intent_kw\
          \ = ['检查', 'PRD', 'prd', '文档', '需求文档', '产品需求',\\n                     '这份',\
          \ '怎么样', '好不好', '有没有问题', '帮我看看',\\n                     '检查一下', '看看这份',\
          \ '审一下', '评审', '风险',\\n                     '审查', '审核', '校验', '规范']\\n \
          \   label_intent_kw = ['标注', '分类', '这些反馈', '这些评论',\\n                  \
          \     '这些评价', '帮我标', '帮我分', '全部反馈', '所有反馈',\\n                       '生成报告',\
          \ '标注报告', '帮我分析这些', '批量分类',\\n                       '批量处理', '批量标注']\\n\
          \    prd_intent = any(k in user_query for k in prd_intent_kw)\\n    label_intent\
          \ = any(k in user_query for k in label_intent_kw)\\n\\n    if has_file:\\\
          n        if prd_intent and not label_intent:\\n            return {\\n \
          \               'validated_type': 'prd_review_file',\\n                'confidence':\
          \ 0.95\\n            }\\n        elif label_intent:\\n            return\
          \ {\\n                'validated_type': 'data_label_file',\\n          \
          \      'confidence': 0.95\\n            }\\n        elif not user_query.strip():\\\
          n            return {\\n                'validated_type': 'prd_review_file',\\\
          n                'confidence': 0.85\\n            }\\n        else:\\n \
          \           return {\\n                'validated_type': 'prd_review_file',\\\
          n                'confidence': 0.8\\n            }\\n\\n    try:\\n    \
          \    cleaned = classifier_output.strip()\\n        if cleaned.startswith('```'):\\\
          n            cleaned = cleaned.split('\\\\n', 1)[-1]\\n            cleaned\
          \ = cleaned.rsplit('```', 1)[0]\\n        cleaned = cleaned.strip()\\n\\\
          n        brace_count = 0\\n        start = -1\\n        for i, c in enumerate(cleaned):\\\
          n            if c == '{':\\n                if brace_count == 0:\\n    \
          \                start = i\\n                brace_count += 1\\n       \
          \     elif c == '}':\\n                brace_count -= 1\\n             \
          \   if brace_count == 0 and start >= 0:\\n                    data = json.loads(cleaned[start:i+1])\\\
          n                    break\\n        else:\\n            data = {}\\n\\\
          n        if data:\\n            raw_type = data.get('type', '')\\n     \
          \       confidence = float(data.get('confidence', 0))\\n            type_map\
          \ = {\\n                'feedback': 'feedback_classify',\\n            \
          \    'prd_check': 'prd_check',\\n                'scene_declare': 'scene_declare',\\\
          n                'invalid_input': 'invalid_input',\\n                'batch':\
          \ 'data_label_file'\\n            }\\n            if raw_type in type_map:\\\
          n                llm_type = type_map[raw_type]\\n    except:\\n        pass\\\
          n\\n    short_negatives = ['卡', '差', '烂', '慢', '崩', '坏', '不好', '不行',\\n\
          \                       '难用', '垃圾', '废了', '废', '渣', '坑']\\n    if len(user_query.strip())\
          \ <= 3 and user_query.strip() in short_negatives:\\n        return {\\n\
          \            'validated_type': 'data_label_text',\\n            'confidence':\
          \ 0.7\\n        }\\n\\n    prd_structures = [\\n        '模块支持', '模块实现',\
          \ '需要支持', '需要实现', '需要提供',\\n        '支持多租户', '支持SSO', '支持RBAC', '支持SKU',\\\
          n        '页面：', '功能：', '需求：',\\n        '点击获取', '输入手机号', '验证码.*有效',\\n \
          \       '动态变化', '实时展示', '跳转.*页',\\n        '多租户隔离', '单点登录', '权限控制',\\n \
          \   ]\\n    has_prd_structure = False\\n    for pattern in prd_structures:\\\
          n        if re.search(pattern, user_query):\\n            has_prd_structure\
          \ = True\\n            break\\n\\n    prd_tech_terms = ['Webhook', 'OAuth',\
          \ 'API', 'CDN', 'Redis', 'SDK',\\n                      'Token', '微服务',\
          \ '回调', '鉴权']\\n    has_prd_tech = False\\n    for term in prd_tech_terms:\\\
          n        if term in user_query and not any(k in user_query for k in ['闪退',\
          \ '崩溃', '报错', '不能用', '坏了', '垃圾', '太慢', '卡顿']):\\n            has_prd_tech\
          \ = True\\n            break\\n\\n    fb_strong = ['闪退', '崩溃', '卡顿', '垃圾',\
          \ '太慢', '不好用', '难用',\\n                 '不能用', '不工作', '报错', '坏了', '失灵',\
          \ '太差', '坑',\\n                 '无语', '气死', '找不到', '没反应', '不方便', '不实用',\\\
          n                 '不如', '还不如', '说好的', '太麻烦', '反人类', '智障',\\n           \
          \      '差', '烂', '烦死', '恶心', '骗人', '退款', '投诉',\\n                 '修了',\
          \ '赶紧', '什么时候修', '怎么还不', '为什么不能',\\n                 '不好', '不行', '好用多了',\
          \ '竞品', '严重',\\n                 '经常失败', '总是失败', '频繁出错', '一直报错']\\n    fb_product\
          \ = ['机器人', '扫地', '充电', '电池', 'APP', '蓝牙', 'WiFi',\\n                  '噪音',\
          \ '吸力', '路径', '建图', '断开', '迷路', '充了',\\n                  '会员', '付费', '订阅',\
          \ '扫地机', '拖地', '避障', '漏扫',\\n                  '基站', '水箱', '尘盒', '滤网', '边刷',\
          \ '滚刷', '地图',\\n                  '清扫', '回充', '离线', '固件', '升级失败', '连接失败',\\\
          n                  '语音', '摄像头', '门锁', '开关', '灯', '插座', '温控',\\n        \
          \          '传感器', '报警', '监控', '推送', '通知', '加载', '白屏',\\n               \
          \   '黑屏', '登录', '注册', '支付', '下单', '搜索', '评论',\\n                  '分享',\
          \ '收藏', '上传', '下载', '播放', '卡住', '死机',\\n                  '重启', '耗电', '发热',\
          \ '闪屏', '花屏', '延迟', '掉线']\\n    prd_keywords = ['模块', '需求', 'PRD', '管理',\
          \ '页面',\\n                    '流程', '字段', '概要', '规格', '设计',\\n         \
          \           '原型', '交互', '用例', '评审', '版本', '迭代',\\n                    '里程碑',\
          \ '排期', '依赖', '前置条件',\\n                    '验收标准', '功能描述', '业务逻辑', '状态机']\\\
          n    scene_keywords = ['做', '行业', 'ToC', 'ToB', '社交', '电商', '金融',\\n   \
          \                   '教育', '产品是', '方向', '赛道', '垂直', '领域',\\n            \
          \          '我在做', '我们做', '公司做', '项目是']\\n    scene_patterns = ['我们公司做',\
          \ '我在做', '我们做', '公司做',\\n                      '产品是', '项目是', '做.*行业', '做.*方向',\\\
          n                      '做.*赛道', '做.*领域', '做.*的$']\\n    has_scene_pattern\
          \ = any(re.search(p, user_query) for p in scene_patterns)\\n\\n    mild_suggest\
          \ = ['能不能加', '能不能有', '能不能支持', '能不能优化',\\n                    '希望能', '希望有',\
          \ '希望增加', '希望支持',\\n                    '可以加', '可以有', '可以增加', '可以支持',\\\
          n                    '建议加', '建议增加', '建议支持', '建议优化',\\n                 \
          \   '想要', '想加', '想要有']\\n    has_mild_suggest = any(s in user_query for\
          \ s in mild_suggest)\\n\\n    strong_count = sum(1 for k in fb_strong if\
          \ k in user_query)\\n    product_count = sum(1 for k in fb_product if k\
          \ in user_query)\\n    fb_count = strong_count + product_count\\n    prd_count\
          \ = sum(1 for k in prd_keywords if k in user_query)\\n    scene_count =\
          \ sum(1 for k in scene_keywords if k in user_query)\\n\\n    consult_patterns\
          \ = ['怎么连接', '如何连接', '怎么配网', '如何配网',\\n                        '怎么使用', '如何使用',\
          \ '怎么安装', '如何安装',\\n                        '怎么设置', '如何设置', '教程', '说明书',\\\
          n                        '怎么连接WiFi', '如何连接WiFi']\\n    is_consult = any(p\
          \ in user_query for p in consult_patterns)\\n\\n    if strong_count > 0:\\\
          n        base_type = 'feedback_classify'\\n    elif has_scene_pattern and\
          \ strong_count == 0:\\n        base_type = 'scene_declare'\\n    elif has_prd_structure\
          \ and strong_count == 0:\\n        base_type = 'prd_check'\\n    elif has_prd_tech\
          \ and strong_count == 0:\\n        base_type = 'prd_check'\\n    elif has_mild_suggest\
          \ and strong_count == 0:\\n        base_type = 'feedback_classify'\\n  \
          \  elif fb_count > prd_count and fb_count > scene_count:\\n        base_type\
          \ = 'feedback_classify'\\n    elif prd_count > 0 and prd_count >= fb_count:\\\
          n        base_type = 'prd_check'\\n    elif scene_count > 0 and scene_count\
          \ > prd_count:\\n        base_type = 'scene_declare'\\n    elif product_count\
          \ > 0:\\n        base_type = 'feedback_classify'\\n    else:\\n        base_type\
          \ = 'invalid_input'\\n\\n    if base_type == 'feedback_classify' and strong_count\
          \ == 0 and is_consult:\\n        product_func_words = ['WiFi', 'wifi', '蓝牙',\
          \ '连接', '配网', '登录', '注册',\\n                              '支付', '清扫', '建图',\
          \ '避障', '充电', '回充',\\n                              'APP', 'app', '固件',\
          \ '升级', '更新', '门锁',\\n                              '摄像头', '传感器', '指纹',\
          \ '语音', '网络']\\n        if not any(w in user_query for w in product_func_words):\\\
          n            base_type = 'invalid_input'\\n\\n    if base_type == 'invalid_input'\
          \ and llm_type and llm_type != 'invalid_input':\\n        base_type = llm_type\\\
          n\\n    if base_type == 'prd_check':\\n        validated_type = 'prd_review_text'\\\
          n    elif base_type == 'feedback_classify':\\n        validated_type = 'data_label_text'\\\
          n    elif base_type == 'scene_declare':\\n        validated_type = 'scene_declare'\\\
          n    else:\\n        validated_type = 'invalid_input'\\n\\n    return {\\\
          n        'validated_type': validated_type,\\n        'confidence': confidence\\\
          n    }\\n"
        "code_language": "python3"
        "outputs":
          "confidence":
