          n    report.append('')\\n    report.append('## \U0001F4CB 逐条标注结果')\\n  \
          \  report.append('')\\n    report.append('| 序号 | 反馈内容 | 问题类型 | 情绪 | 优先级\
          \ | 场景 | 隐含需求 | 用户标签 |')\\n    report.append('| --- | --- | --- | --- |\
          \ --- | --- | --- | --- |')\\n    for item in items:\\n        need_str\
          \ = item.get('implicit_need', '') if item.get('implicit_need') and item['implicit_need']\
          \ != '无' else ''\\n        tag_str = item.get('user_tags', '') if item.get('user_tags')\
          \ and item['user_tags'] != '无' else ''\\n        scene_str = item.get('scene',\
          \ '')\\n        text_esc = item.get('text', '').replace('|', '｜')\\n   \
          \     report.append(f'| {item.get(\\\"index\\\", \\\"\\\")} | {text_esc}\
          \ | {item.get(\\\"type_cn\\\", \\\"\\\")} | {item.get(\\\"sentiment\\\"\
          , \\\"\\\")} | {item.get(\\\"priority\\\", \\\"\\\")} | {scene_str} | {need_str}\
          \ | {tag_str} |')\\n\\n    report.append('')\\n    report.append('---')\\\
          n    report.append('')\\n    report.append('## \U0001F4E5 导出数据')\\n    report.append('')\\\
          n    report.append('复制以下CSV内容，粘贴到记事本保存为 `.csv` 文件，即可用Excel打开：')\\n    report.append('')\\\
          n    report.append('```csv')\\n    report.append(csv_content.strip())\\\
          n    report.append('```')\\n    report.append('')\\n    report.append('\U0001F4A1\
          \ 如需对某条反馈做更精确的分类，请单独粘贴该条内容。')\\n\\n    return {'output': '\\\\n'.join(report)}\\\
          n"
        "code_language": "python3"
