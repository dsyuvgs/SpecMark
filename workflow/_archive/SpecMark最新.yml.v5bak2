          n                return ('性能', '负向', '中')\\n        if re.search(r'不同步',\
          \ text):\\n            if re.search(r'数据|状态|信息|订单|库存|记录', text):\\n    \
          \            return ('功能', '负向', '中')\\n            if not re.search(r'字幕|歌词|翻译',\
