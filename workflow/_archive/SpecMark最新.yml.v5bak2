          \ '体验', '负向', '高'),\\n        ]\\n        perf_rules= [\\n            (['卡顿',\
          \ '太卡了', '很卡', '变卡', '不流畅',\\n              '卡得','卡的要死', '卡死了', '卡的要命'],\
          \ '性能', '负向', '中'),\\n            (['加载慢', '启动慢','打开慢', '响应慢', '运行慢',\\\
          n              '限速', '上传限速'], '性能', '负向', '中'),\\n           (['延迟高', '网络延迟',\
          \ '高延迟'], '性能', '负向', '中'),\\n            (['耗电','费电', '掉电快', '发烫', '过热',\\\
          n              '续航虚标', '续航差', '电池掉电'], '性能','负向', '中'),\\n            (['掉帧',\
          \ '帧率低', '不跟手', '画面不流畅'], '性能', '负向', '中'),\\n           (['缓冲', '转圈圈',\
          \ '一直转圈', 'loading', '缓冲中', '转半天'], '性能', '负向','中'),\\n            (['占用高',\
          \ '内存高', '资源占用', '假死', 'CPU高',\\n             '占用太大', '占用太多', '包太大', '安装包大',\
          \ '更新包大'], '性能', '负向', '中'),\\n        ]\\n       content_rules = [\\n \
          \           (['推荐不准', '推荐不好', '推荐单一', '推荐重复','推荐过时',\\n              '推荐越来越',\
          \ '同质化'], '内容', '负向', '中'),\\n           (['搜索不对', '搜不到', '搜出来不对', '搜索结果不相关',\\\
          n              '版权覆盖太少'], '内容','负向', '中'),\\n            (['匹配不公', '匹配机制',\
          \ '算法有问题', '算法推荐'], '内容', '负向','中'),\\n            (['翻译错', '字幕不同步', '歌词延迟',\
          \ '歌词翻译不对'], '内容', '负向', '中'),\\n           (['图文不符', '描述不符', '实物不符', '刷评',\
          \ '水军',\\n              '内容过时','信息旧', '攻略过时', '信息过时'], '内容', '负向', '中'),\\\
          n            (['黄色', '暧昧信息','低俗', '戾气'], '内容', '负向', '中'),\\n          \
          \  (['数据有延迟', '数据延迟'], '内容','负向', '低'),\\n        ]\\n        suggest_rules\
          \ = [\\n            (['能不能','希望', '建议', '想要', '加个', '能不能加'], '体验', '中性',\
          \ '低'),\\n        ]\\n       other_exp_rules = [\\n            (['广告', '推送太多',\
          \ '操作复杂', '找不到入口', '太贵','涨价',\\n              '会员', '退款', '售后', '诱导', '套路',\
          \ '权益缩水',\\n             'VIP专属', '免费用户', '吃相'], '体验', '负向', '低'),\\n  \
          \          (['太麻烦', '繁琐','找不到', '难找', '不方便', '不好用',\\n              '难用',\
          \ '步骤太多', '设置太深', '隐藏得太深','太复杂'], '体验', '负向', '低'),\\n            (['预售',\
          \ '发货时间', '没发货', '物流', '发货'],'体验', '负向', '中'),\\n            (['配送费'], '体验',\
          \ '负向', '低'),\\n        ]\\n       all_rules = func_rules + svc_rules +\
          \ perf_rules + content_rules+ suggest_rules + other_exp_rules\\n       \
          \ for keywords, ptype, sentiment,priority in all_rules:\\n            if\
          \ any(k in text for k in keywords):\\n               return (ptype, sentiment,\
          \ priority)\\n        if re.search(r'(?:太|很|特别|变|更|越|也|都|还是|就是).*卡|卡(?:顿|住|得|的|了)',text):\\\
          n            if not re.search(r'银行卡|打卡|会员卡|卡通|卡片|卡包', text):\\n        \
          \       return ('性能', '负向', '中')\\n        if re.search(r'(?:太|很|特别|更|越).*慢|慢(?:了|得|的)',text):\\\
          n            if not re.search(r'回复.*慢|问诊|医生|客服.*慢|退款|售后|审核|物流|发货|配送',text):\\\
          n                return ('性能', '负向', '中')\\n        if re.search(r'启动.{0,3}\\\
          \\d+秒|启动要|打开要', text):\\n            return ('性能', '负向', '中')\\n       \
          \ if '续航'in text:\\n            return ('性能', '负向', '中')\\n        if '假死'\
          \ in text:\\n           return ('性能', '负向', '中')\\n        if '限速' in text:\\\
          n           return ('性能', '负向', '中')\\n        if re.search(r'(?:资源|内存|CPU).*(?:占用|高|大|太多)',text):\\\
          n            return ('性能', '负向', '中')\\n        if re.search(r'转.{0,3}圈',text):\\\
          n            if not re.search(r'朋友圈|社交圈', text):\\n               return\
          \ ('性能', '负向', '中')\\n        if re.search(r'手机.{0,3}烫|烫.{0,3}手',text):\\\
          n            return ('性能', '负向', '中')\\n        if re.search(r'数据.{0,2}延迟|汇率.*延迟|牌价.*延迟',text):\\\
          n            return ('内容', '负向', '低')\\n        if '描述不符' in textor '实物不符'\
          \ in text or '缺斤少两' in text:\\n            return ('内容', '负向','中')\\n  \
          \      if re.search(r'刷.{0,1}评|假评|水军|五星好评', text):\\n           return ('内容',\
          \ '负向', '中')\\n        if '杀熟' in text:\\n            return('体验', '负向',\
          \ '高')\\n        if re.search(r'退款|售后|退货|换货|拒赔', text):\\n           return\
          \ ('体验', '负向', '低')\\n        if re.search(r'配送|骑手|司机|打车|叫车|网约车|顺风车|拼车|接单|接机',text):\\\
          n            return ('体验', '负向', '低')\\n        if '客服' in text:\\n    \
          \       return ('体验', '负向', '中')\\n        if re.search(r'广告|推送|弹窗|开屏',text):\\\
          n            return ('体验', '负向', '低')\\n        if re.search(r'太贵|涨价|价格|不值|性价比|抽奖|充更多',text):\\\
          n            return ('体验', '负向', '低')\\n        if re.search(r'会员|VIP|付费|充值|续费|红包|权益',text):\\\
          n            return ('体验', '负向', '低')\\n        if re.search(r'能不能|希望|建议|想要|加个',text):\\\
          n            return ('体验', '中性', '低')\\n        if re.search(r'找不到|复杂|麻烦|繁琐|难找|不方便|设置太深|隐私设置',text):\\\
          n            return ('体验', '负向', '低')\\n        if re.search(r'定位不准|定位偏差',text):\\\
          n            return ('功能', '负向', '中')\\n        if re.search(r'照片被压缩|画质.*变|压缩.*模糊',text):\\\
          n            return ('功能', '负向', '中')\\n        if re.search(r'折叠|翻半天',text):\\\
          n            return ('体验', '负向', '低')\\n        if '无法撤回' in text:\\n  \
          \         return ('功能', '负向', '中')\\n        if re.search(r'账户.{0,2}限制|账户.{0,2}冻结|限制.*转账|限制.*提现',text):\\\
          n            return ('功能', '负向', '高')\\n        if re.search(r'审核不通过|审核.*拒绝',text):\\\
          n            return ('功能', '负向', '高')\\n        if re.search(r'额度太低|额度不够',text):\\\
          n            return ('体验', '负向', '低')\\n        if re.search(r'到店.*没房|预订.*没房|没房了',text):\\\
          n            return ('体验', '负向', '高')\\n        if re.search(r'没人接单|没接单',text):\\\
          n            return ('体验', '负向', '中')\\n        if re.search(r'次日达|等了\\\\\
          d+天|等了\\\\d+分钟', text):\\n            return ('体验', '负向', '中')\\n      \
          \  ifre.search(r'信息过时|早就关门|攻略.*过时', text):\\n            return ('内容', '负向','中')\\\
          n        if re.search(r'规则不透明|不透明', text):\\n            return ('体验','负向',\
          \ '低')\\n        if re.search(r'威胁|骚扰|疯狂打电话', text):\\n            return('体验',\
          \ '负向', '高')\\n        if re.search(r'重影|竖条|刮痕|显示屏', text):\\n         \
          \  return ('体验', '负向', '高')\\n        if re.search(r'运费|退货.*运费', text):\\\
          n           return ('体验', '负向', '低')\\n        if re.search(r'材质.*不符|手感.*不一样',text):\\\
          n            return ('内容', '负向', '中')\\n        if re.search(r'功能臃肿|臃肿|花里胡哨',text):\\\
          n            return ('体验', '负向', '低')\\n        if re.search(r'bug|Bug|BUG',text):\\\
          n            return ('功能', '负向', '中')\\n        if re.search(r'崩了|大面积故障|服务异常',text):\\\
          n            return ('功能', '负向', '高')\\n        if re.search(r'不实时同步|不.*同步|要刷新',text):\\\
          n            return ('功能', '负向', '中')\\n        if re.search(r'识别为外出|打卡.*迟到|打卡.*外勤',text):\\\
          n            return ('功能', '负向', '高')\\n        if re.search(r'付费推广|前五页',text):\\\
          n            return ('体验', '负向', '中')\\n        if re.search(r'已读回执|已读',text):\\\
          n            return ('体验', '中性', '低')\\n        return None\\n\\n   result\
          \ = iron_classify(text)\\n    if result:\\n        ptype, sentiment, iron_priority\
          \ = result\\n        source = '铁律拦截'\\n    else:\\n        llm_result= {}\\\
          n        try:\\n            raw = str(feature_json).strip()\\n         \
          \  if raw.startswith('```'):\\n                raw = raw.split('\\\\n',\
          \ 1)[-1].rsplit('```', 1)[0].strip()\\n            llm_result = json.loads(raw)\\\
          n           if not isinstance(llm_result, dict):\\n                llm_result=\
          \ {}\\n        except (json.JSONDecodeError, TypeError, ValueError):\\n\
          \           pass\\n        if llm_result.get('problem_type') in ['功能', '性能','体验',\
          \ '内容']:\\n            ptype = llm_result['problem_type']\\n           sentiment\
          \ = llm_result.get('sentiment', '负向')\\n            if sentimentnot in ['负向',\
          \ '中性', '正向']:\\n                sentiment = '负向'\\n           if iron_priority\
          \ is not None:\\n                priority = iron_priority\\n           \
          \ else:\\n                priority = llm_result.get('priority', '低')\\n\
          \                if priority not in ['高', '中', '低']:\\n                \
          \    priority = '低'\\n            source= 'LLM分析'\\n        else:\\n   \
          \         ptype, sentiment, priority = '体验','中性', '低'\\n            source\
          \ = '安全兜底'\\n\\n    type_map = {'功能': '功能问题','性能': '性能问题', '体验': '体验问题',\
          \ '内容': '内容问题'}\\n    type_cn = type_map.get(ptype,ptype)\\n    tag_str\
          \ = ', '.join(tags) if tags else '无'\\n\\n    output =f\\\"\\\\U0001F4CB\
          \ 分类结果\\\\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\\\n\\\\U0001F3AD 情绪：{sentiment}\\\
          \\n\\\\U0001F4C2 类型：{type_cn}\\\\n\\\\U0001F534 优先级：{priority}\\\\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━\\\
          \\n\\\\U0001F4CC 场景：{scene or '未指定'}\\\\n\\\\U0001F4A1 核心功能：{'是' if core\
          \ else '否'}\\\\n\\\\U0001F464 用户标签：{tag_str}\\\\n\\\\U0001F52E 隐含需求：{need}\\\
          \\n\\\\U0001F3F7️ 来源：{source}\\\"n\\n    return {\\n        'output': output,\\\
          n        'problem_type': ptype,\\n       'sentiment': sentiment,\\n    \
          \    'priority': priority,\\n       'user_tags': tag_str,\\n        'implicit_need':\
          \ need,\\n        'is_core':core\\n    }\\n"
        "code_language": "python3"
        "outputs":
          "implicit_need":
            "children": null
            "type": "string"
          "is_core":
            "children": null
