    - "data":
        "code": "import json\\nimport csv\\nimport io\\n\\ndef main(batch_output:\
          \ str, total: int) -> dict:\\n    if not batch_output:\\n        return\
          \ {'output': '⚠️ 未接收到分类结果'}\\n\\n    items = []\\n    try:\\n        data\
          \ = json.loads(str(batch_output))\\n        if isinstance(data, list):\\\
          n            items = data\\n    except (json.JSONDecodeError, TypeError):\\\
          n        pass\\n\\n    if not items:\\n        return {'output': '⚠️ 无法解析分类结果，请确保上传了有效文件'}\\\
          n\\n    type_map = {'功能': '功能问题', '性能': '性能问题', '体验': '体验问题', '内容': '内容问题'}\\\
          n    for item in items:\\n        item['type_cn'] = type_map.get(item.get('problem_type',\
          \ ''), item.get('problem_type', ''))\\n\\n    total = len(items)\\n    type_counts\
          \ = {}\\n    sentiment_counts = {}\\n    priority_counts = {}\\n    for\
          \ item in items:\\n        t = item.get('type_cn', '')\\n        type_counts[t]\
          \ = type_counts.get(t, 0) + 1\\n        s = item.get('sentiment', '')\\\
          n        sentiment_counts[s] = sentiment_counts.get(s, 0) + 1\\n       \
          \ p = item.get('priority', '')\\n        priority_counts[p] = priority_counts.get(p,\
          \ 0) + 1\\n\\n    high_items = [i for i in items if i.get('priority') ==\
          \ '高']\\n\\n    csv_buf = io.StringIO()\\n    csv_writer = csv.writer(csv_buf)\\\
          n    csv_writer.writerow(['序号', '反馈内容', '问题类型', '情绪', '优先级', '场景', '隐含需求',\
          \ '用户标签'])\\n    for item in items:\\n        csv_writer.writerow([\\n \
          \           item.get('index', ''),\\n            item.get('text', ''),\\\
          n            item.get('type_cn', ''),\\n            item.get('sentiment',\
          \ ''),\\n            item.get('priority', ''),\\n            item.get('scene',\
          \ ''),\\n            item.get('implicit_need', '') if item.get('implicit_need')\
          \ and item['implicit_need'] != '无' else '',\\n            item.get('user_tags',\
          \ '') if item.get('user_tags') and item['user_tags'] != '无' else ''\\n \
          \       ])\\n    csv_content = csv_buf.getvalue()\\n\\n    report = []\\\
          n    report.append(f'## \U0001F4CA 统计摘要（共{total}条）')\\n    report.append('')\\\
          n    report.append(f'**总计：{total} 条反馈**')\\n    report.append('')\\n\\n\
          \    report.append('━━━━━━━━━━━━━━━━━━━━━━━━━━━━')\\n    report.append('###\
          \ 问题类型分布')\\n    for t in ['功能问题', '性能问题', '体验问题', '内容问题']:\\n        c\
          \ = type_counts.get(t, 0)\\n        pct = c / total * 100 if total > 0 else\
          \ 0\\n        bar = '█' * int(pct / 5) + '░' * (20 - int(pct / 5))\\n  \
          \      report.append(f'- {t}：{c}条 ({pct:.1f}%) {bar}')\\n    report.append('')\\\
          n\\n    report.append('### 情绪分布')\\n    for s in ['负向', '中性', '正向']:\\n\
          \        c = sentiment_counts.get(s, 0)\\n        pct = c / total * 100\
          \ if total > 0 else 0\\n        bar = '█' * int(pct / 5) + '░' * (20 - int(pct\
          \ / 5))\\n        report.append(f'- {s}：{c}条 ({pct:.1f}%) {bar}')\\n   \
          \ report.append('')\\n\\n    report.append('### 优先级分布')\\n    for p, emoji\
          \ in [('高', '\U0001F534'), ('中', '\U0001F7E1'), ('低', '\U0001F7E2')]:\\\
          n        c = priority_counts.get(p, 0)\\n        pct = c / total * 100 if\
          \ total > 0 else 0\\n        bar = '█' * int(pct / 5) + '░' * (20 - int(pct\
          \ / 5))\\n        report.append(f'- {emoji}{p}：{c}条 ({pct:.1f}%) {bar}')\\\
          n    report.append('━━━━━━━━━━━━━━━━━━━━━━━━━━━━')\\n\\n    if high_items:\\\
          n        report.append('')\\n        report.append(f'### ⚠️ 高优先级反馈（{len(high_items)}条）')\\\
          n        for item in high_items[:30]:\\n            report.append(f'- [{item.get(\\\
          \"type_cn\\\", \\\"\\\")}] {item.get(\\\"text\\\", \\\"\\\")}')\\n     \
          \   if len(high_items) > 30:\\n            report.append(f'- ... 还有{len(high_items)\
          \ - 30}条高优先级反馈')\\n\\n    report.append('')\\n    report.append('---')\\\
          n    report.append('')\\n    report.append('## \U0001F4CB 逐条标注结果')\\n  \
          \  report.append('')\\n    report.append('| 序号 | 反馈内容 | 问题类型 | 情绪 | 优先级\
          \ | 场景 | 隐含需求 | 用户标签 |')\\n    report.append('| --- | --- | --- | --- |\
          \ --- | --- | --- | --- |')\\n    for item in items:\\n        need_str\
          \ = item.get('implicit_need', '') if item.get('implicit_need') and item['implicit_need']\
          \ != '无' else ''\\n        tag_str = item.get('user_tags', '') if item.get('user_tags')\
          \ and item['user_tags'] != '无' else ''\\n        scene_str = item.get('scene',\
          \ '')\\n        text_esc = item.get('text', '').replace('|', '｜')\\n   \
          \     report.append(f'| {item.get(\\\"index\\\", \\\"\\\")} | {text_esc}\
          \ | {item.get(\\\"type_cn\\\", \\\"\\\")} | {item.get(\\\"sentiment\\\"\
          , \\\"\\\")} | {item.get(\\\"priority\\\", \\\"\\\")} | {scene_str} | {need_str}\
          \ | {tag_str} |')\\n\\n    report.append('')\\n    report.append('---')\\\
          n    report.append('')\\n    report.append('## \U0001F4E5 导出数据')\\n    report.append('')\\\
          n    report.append('复制以下CSV内容，粘贴到记事本保存为 `.csv` 文件，即可用Excel打开：')\\n    report.append('')\\\
          n    report.append('```csv')\\n    report.append(csv_content.strip())\\\
          n    report.append('```')\\n    report.append('')\\n    report.append('\U0001F4A1\
          \ 如需对某条反馈做更精确的分类，请单独粘贴该条内容。')\\n\\n    return {'output': '\\\\n'.join(report)}\\\
          n"
