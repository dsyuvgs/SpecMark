          \ 'CPU高',\\n              '占用太大', '占用太多', '包太大', '安装包大', '更新包大'], '性能',\
          \ '负向', '中'),\\n            (['画面延迟', '声音延迟', '画面不同步', '声音不同步'], '性能', '负向',\
          \ '中'),\\n        ]\\n        content_rules = [\\n            (['推荐不准',\
          \ '推荐不好', '推荐单一', '推荐重复', '推荐过时',\\n              '推荐越来越', '同质化'], '内容',\
          \ '负向', '中'),\\n            (['搜索不对', '搜不到', '搜出来不对', '搜索结果不相关',\\n    \
          \          '版权覆盖太少'], '内容', '负向', '中'),\\n            (['匹配不公', '匹配机制',\
