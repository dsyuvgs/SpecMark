          \ text):\\n        return ('体验', '负向', None)\\n    if re.search(r'已读回执|已读',\
          \ text):\\n        return ('体验', '中性', None)\\n    return None\\n      \
          \  has_func_failure = bool(re.search(\\n            r'闪退|崩溃|死机|白屏|黑屏|变砖|强制退出|ANR|'\\\
          n            r'支付失败|扣款异常|重复扣款|数据丢失|登录不上|账号被盗|'\\n            r'隐私泄露|隐私暴露|不明扣款|打不开|一片空白|404|'\\\
